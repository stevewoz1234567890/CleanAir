    {
        "_id": "5fbd80320aa1ec4824bfc1b7",
        "name": "VSF",
        "formula": "= IF(\n    AND(\n        [5fb7f24ef678081d443ae270], \n        [5fb7f24ef678081d443ae270] > 0.01\n    ),\n    ([5fb7f24ef678081d443ae270]*(1000/4)*[5f061f773103cc4b0fb1f4b5])/[5fb7f09b2d14ea1cd8a8371b(mw)],\n    0\n)",
        "to": "flare",
        "dataType": "num",
        "org": "5fb6b7ea6b029226f07d2677",
        "createdDate": "2020-11-24 21:50:42.129000",
        "lastUpdate": "2020-11-24 21:50:42.129000",
        "__v": 0,
        "newFormula": "let steam = parameter(5fdd469a79ee804cbc389d24);\nlet mw = constant(5f061f773103cc4b0fb1f4b5);\nlet water = compound(5fb7f09b2d14ea1cd8a8371b,'molecularWeight');\n\n= IF(\n  AND(steam, steam > 0.01),\n  (steam*(1000/4)*mw)/water,\n  0)"
    },
