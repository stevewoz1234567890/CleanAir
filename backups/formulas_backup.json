        "name": "Header Primary CEMS Avail",
        "formula": "=AND(\n    (COUNTIF([5fb7f254f678081d443ae295(primary)],\"NORMAL\") + \n    COUNTIF([5fb7f254f678081d443ae295(primary)],\"OK\") )>6, \n    \n    (COUNTIF([5fb7f255f678081d443ae29b(primary)],\"NORMAL\") + \n    COUNTIF([5fb7f255f678081d443ae29b(primary)],\"OK\") )>6,\n    \n    COUNTIF([5fb7f255f678081d443ae29c(primary)],\"NORMAL\") = 15, \n    \n    OR(\n        SUM([5f7e4c6a74c55e499c73ea89(fractional)]) < 0.8 , \n        SUM([5f7e4c6a74c55e499c73ea89(fractional)]) > 1.2 \n    )=FALSE \n)",
