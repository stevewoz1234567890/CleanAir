        "org": "5fb6b7ea6b029226f07d2677",
        "createdDate": "2020-11-24 21:50:42.398000",
        "lastUpdate": "2020-11-24 21:50:42.398000",
        "__v": 0,
        "newFormula": "let primary = formula(5fbd80320aa1ec4824bfc1bc);\nlet secondary = formula(5fbd80320aa1ec4824bfc1ca);\nlet prifracs = compoundGroup(5fc6db3d460ef84d37f33f42,'fractional','primary');\nlet secfracs = compoundGroup(5fc6db3d460ef84d37f33f42,'fractional','secondary');\nlet nhvs = compoundGroup(5fc6db3d460ef84d37f33f42,'netHeatingValue');\n\n=IF(primary,SUM( prifracs * nhvs ),IF(secondary,SUM( secfracs * nhvs ), NULL))\n"
    },
